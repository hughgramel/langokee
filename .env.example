# ─── Forced alignment (WhisperX) ─────────────────────────────────────────
# langokee never runs open-vocabulary ASR — the text you paste in the
# upload modal is the ground truth. We only run the wav2vec2 CTC
# alignment stage from WhisperX to answer WHEN each word lands in the
# audio. See scripts/align.py for the full pipeline.
#
# Point ALIGN_PYTHON at an interpreter that has `whisperx` installed.
# Recommended: a dedicated venv (pyenv + uv venv works on macOS).
ALIGN_PYTHON=python3

# "cpu" is fine for ~5min tracks on Apple Silicon. Use "cuda" on Linux
# boxes with an NVIDIA GPU.
ALIGN_DEVICE=cpu

# ─── yt-dlp / ffmpeg ─────────────────────────────────────────────────────
# Override if not on PATH. Defaults are `yt-dlp` and `ffmpeg`.
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg

# ─── AnkiConnect ─────────────────────────────────────────────────────────
# Default is the stock AnkiConnect port on localhost.
ANKI_CONNECT_URL=http://127.0.0.1:8765
ANKI_DECK_NAME=Timestamp
ANKI_MODEL_NAME=Timestamp Sentence
